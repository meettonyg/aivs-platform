generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────
// Auth & Multi-Tenancy
// ──────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String?   @map("password_hash")
  image         String?
  role          String    @default("user") // user | admin | superadmin
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  memberships   OrgMember[]
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refreshToken      String? @map("refresh_token") @db.Text
  accessToken       String? @map("access_token") @db.Text
  expiresAt         Int?    @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token") @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Organization {
  id                    String   @id @default(cuid())
  name                  String
  slug                  String   @unique
  planTier              String   @default("free") @map("plan_tier")
  stripeCustomerId      String?  @unique @map("stripe_customer_id")
  stripeSubscriptionId  String?  @unique @map("stripe_subscription_id")
  crawlCreditsMonthly   Int      @default(5) @map("crawl_credits_monthly")
  crawlCreditsRemaining Int      @default(5) @map("crawl_credits_remaining")
  currentPeriodEnd      DateTime? @map("current_period_end")
  settings              Json     @default("{}") // White-label config, branding, etc.
  parentOrgId           String?  @map("parent_org_id") // Agency sub-org support
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  parentOrg Organization?  @relation("AgencyClients", fields: [parentOrgId], references: [id])
  childOrgs Organization[] @relation("AgencyClients")
  members   OrgMember[]
  projects  Project[]
  apiKeys   ApiKey[]
  webhooks  Webhook[]

  @@map("organizations")
}

model OrgMember {
  id             String @id @default(cuid())
  userId         String @map("user_id")
  organizationId String @map("organization_id")
  role           String @default("member") // owner, admin, member, client

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("org_members")
}

// ──────────────────────────────────────
// Projects & Scanning
// ──────────────────────────────────────

model Project {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  domain         String
  name           String
  scheduleFreq   String?  @map("schedule_freq") // weekly, daily, monthly
  lastScheduledAt DateTime? @map("last_scheduled_at")
  siteScore      Int?     @map("site_score") // Aggregate domain-level score
  siteTier       String?  @map("site_tier")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scans        Scan[]
  crawlJobs    CrawlJob[]
  people       ProjectPerson[]
  attributions Attribution[]
  socialAccounts SocialAccount[]

  @@unique([organizationId, domain])
  @@map("projects")
}

// ──────────────────────────────────────
// Authority — People, Attributions, Social
// ──────────────────────────────────────

model ProjectPerson {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String
  role      String?  // CEO, CTO, Author, etc.
  createdAt DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, name])
  @@map("project_people")
}

model Attribution {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  domain       String
  personName   String?  @map("person_name") // null = org-level attribution
  candidateId  String   @map("candidate_id")
  type         String   // book, podcast_episode, youtube_channel, academic_paper, patent, screen_credit, owned_podcast, github_profile
  status       String   // confirmed, rejected
  title        String
  subtitle     String?
  attributedAt DateTime @default(now()) @map("attributed_at")
  attributedBy String   @map("attributed_by")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, candidateId])
  @@map("attributions")
}

model SocialAccount {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  personName   String?   @map("person_name") // null = org-level account
  platform     String    // linkedin, twitter, instagram, tiktok, facebook, pinterest, youtube
  handle       String
  profileUrl   String    @map("profile_url")
  accessToken  String?   @map("access_token") @db.Text  // OAuth, encrypted at rest
  refreshToken String?   @map("refresh_token") @db.Text // OAuth, encrypted at rest
  followers    Int?
  lastFetched  DateTime? @map("last_fetched")
  createdAt    DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, platform, handle])
  @@map("social_accounts")
}

model Scan {
  id                String   @id @default(cuid())
  projectId         String?  @map("project_id")
  url               String
  hash              String   @unique // 12-char MD5
  score             Int
  tier              String
  subScores         Json     @map("sub_scores")
  layerScores       Json     @map("layer_scores")
  extraction        Json     @default("{}")
  fixes             Json     @default("[]")
  citationSimulation Json    @default("{}") @map("citation_simulation")
  robotsData        Json     @default("{}") @map("robots_data")
  pageType          String?  @map("page_type")
  rawText           String?  @map("raw_text") @db.Text
  contentHash       String?  @map("content_hash") // MD5 of body text for incremental re-scans
  competitorData    Json?    @map("competitor_data")
  crawlJobId        String?  @map("crawl_job_id")
  factorVersion     Int      @default(1) @map("factor_version") // 1=27 factors, 2=55 factors
  createdAt         DateTime @default(now()) @map("created_at")

  project  Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  crawlJob CrawlJob? @relation(fields: [crawlJobId], references: [id])

  @@index([projectId, createdAt])
  @@index([url])
  @@index([contentHash])
  @@map("scans")
}

model ScanHistory {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  url         String
  score       Int
  prevScore   Int?     @map("prev_score")
  subScores   Json     @map("sub_scores")
  scannedAt   DateTime @map("scanned_at")

  @@index([projectId, url, scannedAt])
  @@map("scan_history")
}

model CrawlJob {
  id              String    @id @default(cuid())
  projectId       String    @map("project_id")
  status          String    @default("pending") // pending, running, completed, failed
  pagesTotal      Int       @default(0) @map("pages_total")
  pagesCompleted  Int       @default(0) @map("pages_completed")
  pagesSkipped    Int       @default(0) @map("pages_skipped") // Unchanged pages (incremental)
  creditsUsed     Int       @default(0) @map("credits_used")
  maxPages        Int?      @map("max_pages")
  isIncremental   Boolean   @default(false) @map("is_incremental")
  deltaReport     Json?     @map("delta_report") // { improved: [...], declined: [...], new: [...] }
  siteScore       Int?      @map("site_score") // Aggregate score at crawl completion
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scans   Scan[]

  @@index([projectId, createdAt])
  @@map("crawl_jobs")
}

// ──────────────────────────────────────
// API Keys
// ──────────────────────────────────────

model ApiKey {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  keyHash        String    @unique @map("key_hash")
  label          String
  rateLimit      Int       @default(100) @map("rate_limit") // Requests per minute
  scopes         String[]  @default(["scan:read", "scan:write"]) // Permission scopes
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ──────────────────────────────────────
// Webhooks & Alerts (Phase 4)
// ──────────────────────────────────────

model Webhook {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  url            String
  events         String[] // scan.complete, score.changed, crawl.complete, credits.low
  secret         String   // HMAC signing secret
  active         Boolean  @default(true)
  failureCount   Int      @default(0) @map("failure_count")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("webhooks")
}

model Alert {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  projectId      String?  @map("project_id")
  type           String   // score_drop, score_improvement, tier_change, factor_regression, credits_low
  severity       String   // critical, warning, info
  title          String
  message        String   @db.Text
  url            String?
  metadata       Json     @default("{}")
  readAt         DateTime? @map("read_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([organizationId, readAt, createdAt])
  @@map("alerts")
}

// ──────────────────────────────────────
// Platform Settings (Admin)
// ──────────────────────────────────────

model PlatformSettings {
  id                  String   @id @default("singleton")
  defaultCrawlCredits Int      @default(5) @map("default_crawl_credits")
  defaultRateLimit    Int      @default(100) @map("default_rate_limit")
  featureFlags        Json     @default("{}") @map("feature_flags")
  maintenanceMode     Boolean  @default(false) @map("maintenance_mode")
  systemEmailFrom     String?  @map("system_email_from")
  systemEmailReplyTo  String?  @map("system_email_reply_to")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}
